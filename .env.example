# CFPMonitor Environment Variables
# Copy this file to .env and fill in your values

# Search provider (currently only duckduckgo supported)
SEARCH_PROVIDER=duckduckgo

# Optional: If using paid search APIs in the future
# SERPER_API_KEY=your_key_here

# Optional: GitHub integration (for issue tracking, not required for MVP)
# GITHUB_TOKEN=your_token_here
# GITHUB_REPOSITORY=username/CFPMonitor

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Rate limiting (seconds)
RATE_LIMIT_DELAY=1.0

# Archive directory (relative to project root)
ARCHIVE_ROOT=data/raw
